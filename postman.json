        {
          "name": "Get Blogs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{protocol}}://{{baseUrl}}/api/blog?page=1&limit=10",
              "protocol": "{{protocol}}",
              "host": ["{{baseUrl}}"],
