              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Search Blogs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{protocol}}://{{baseUrl}}/api/blog/search?q=edge&page=1&limit=10",
              "protocol": "{{protocol}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "blog", "search"],
              "query": [
                { "key": "q", "value": "edge" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
